---
import Layout from "../layouts/Layout.astro";
import Header from "@components/Header.astro";
import Hero from "@components/Hero.astro";
import Experience from "@components/Experience.astro";
import AboutMe from "@components/AboutMe.astro";
import TechStack from "@components/TechStack.astro";
import CallToAction from "@components/CallToAction.astro";
import Footer from "@components/Footer.astro";

import { aboutParagraphs, jobs, socialLinks, techStackInfo, email, navbarOptions } from "./_information";
---

<Layout>
  <main>
    <Header {navbarOptions} />
    <Hero {socialLinks} {email} />
    <Experience {jobs} />
    <AboutMe paragraphs={aboutParagraphs} />
    <TechStack {techStackInfo} />
    <CallToAction {email} />
    <Footer {socialLinks} />
  </main>
</Layout>

<script>
  const sections: NodeListOf<HTMLElement> = document.querySelectorAll("main > section");
  const navLinks: NodeListOf<HTMLAnchorElement> = document.querySelectorAll(".nav-link");

  const activeSections = new Set<HTMLElement>();
  let lastVisibleSection: HTMLElement | null = null;

  function updateActiveNavLink() {
    navLinks.forEach((link) => link.classList.remove("active"));

    const targetSection = activeSections.size === 1 ? Array.from(activeSections)[0] : lastVisibleSection;

    if (targetSection) {
      const link = document.querySelector<HTMLAnchorElement>(`.nav-link[href="#${targetSection.id}"]`);
      link?.classList.add("active");
    }
  }

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        const section = entry.target as HTMLElement;

        if (entry.isIntersecting) {
          activeSections.add(section);
          lastVisibleSection = section;
        } else {
          activeSections.delete(section);
        }
      }

      updateActiveNavLink();
    },
    {
      rootMargin: "0px 0px -50% 0px",
      threshold: 0.3,
    }
  );

  sections.forEach((section) => observer.observe(section));
</script>

<style>
  main {
    overflow-x: clip;
  }
</style>
