---
import Arrow from "./svgs/Arrow.astro";

type Props = {
  email: string;
};

const { email } = Astro.props;
---

<section>
  <div class="content wrapper">
    <div class="box">
      <div class="call-to-action">
        <h2>Let's work together to build something great!</h2>
        <p>Reach out to me for collaborations, inquiries, or just to say hello.</p>
      </div>

      <div class="contact-button">
        <a href={`mailto:${email}?subject=Hello Fernando!, I would like to work with you`}>
          <span>Send me an email</span>
          <Arrow color="var(--light-90)" />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    padding-bottom: var(--section-spacing);
    position: relative;
  }

  .box {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    background: linear-gradient(90deg, #c6fca6 0%, #7dc1ba 100%);
    color: var(--dark-90);
    padding: 3rem 2rem;
    border-radius: 32px;
  }

  .call-to-action {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }

  h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    font-weight: 600;
    margin: 0;
  }

  p {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 1rem;
    margin: 0;
  }

  .contact-button a {
    padding: 12px 16px;
    background: var(--background-450);
    color: var(--light-90);
    border-radius: 100px;
    font-weight: 500;
    text-decoration: none;
    text-wrap: nowrap;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: background-color 0.2s ease-in-out;
  }

  .contact-button a :global(svg) {
    transform: rotate(-180deg);
    transition: transform 0.2s ease-in-out;
  }

  .contact-button a:hover {
    background: var(--background-500);
  }

  .contact-button a:hover :global(svg) {
    transform: rotate(-45deg);
  }

  @media (max-width: 600px) {
    section {
      padding: var(--section-spacing) 0;
    }

    .box {
      flex-direction: column;
      gap: 2rem;
      padding: 2rem;
    }

    .contact-button {
      width: 100%;
      text-align: center;
    }
  }
</style>
