---
import Arrow from "./svgs/Arrow.astro";
import type { CallToActionCopy } from "./types";

type Props = {
  callToActionCopy: CallToActionCopy;
};

const { callToActionCopy } = Astro.props;
const { email } = callToActionCopy;
---

<section>
  <div class="content wrapper">
    <div class="box">
      <div class="call-to-action">
        <h2>{callToActionCopy.title}</h2>
        <p>{callToActionCopy.subtitle}</p>
      </div>

      <div class="contact-button">
        <a href={`mailto:${email}?subject=Hello Fernando!, I would like to work with you`}>
          <span>{callToActionCopy.emailText}</span>
          <Arrow color="var(--light-90)" />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    padding: var(--section-spacing) 0;
    position: relative;
  }
  .box {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    background: linear-gradient(90deg, #c6fca6 0%, #7dc1ba 100%);
    color: var(--dark-90);
    padding: 3rem 2rem;
    border-radius: 32px;
  }

  .call-to-action {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }

  h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    font-weight: 600;
    margin: 0;
  }

  p {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 1rem;
    margin: 0;
  }

  .contact-button {
    display: flex;
    align-items: center;
  }

  .contact-button a {
    width: 100%;
    padding: 12px 16px;
    background: var(--background-450);
    color: var(--light-90);
    border-radius: 100px;
    font-weight: 500;
    text-decoration: none;
    text-wrap: nowrap;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: background-color 0.2s ease-in-out;
  }

  .contact-button a :global(svg) {
    transform: rotate(0deg);
    transition: transform 0.2s ease-in-out;
  }

  .contact-button a:hover {
    background: var(--background-500);
  }

  .contact-button a:hover :global(svg) {
    transform: rotate(-45deg);
  }

  @media (max-width: 600px) {
    .box {
      flex-direction: column;
      gap: 2rem;
      padding: 2rem;
    }

    .contact-button {
      width: 100%;
      text-align: center;
    }

    .contact-button a {
      justify-content: space-between;
    }
  }
</style>
