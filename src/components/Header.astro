---
import Navbar from "./Navbar.astro";
import ExternalLink from "./svgs/ExternalLink.astro";

const navbarOptions = [
  { label: "Home", href: "#home" },
  { label: "My Experience", href: "#my-experience" },
  { label: "About", href: "#about" },
  { label: "Tech Stack", href: "#tech-stack" },
  { label: "Let's Talk", href: "#contact", icon: ExternalLink },
];
---

<header>
  <Navbar options={navbarOptions} />
</header>
<div class="spacer"></div>

<style>
  .spacer {
    display: block;
    height: 88px;
    width: 100%;
  }

  header {
    position: fixed;
    width: 100%;
    z-index: 1000;

    display: flex;
    justify-content: center;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
</style>
