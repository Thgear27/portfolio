---
import Briefcase from "./svgs/Briefcase.astro";
import type { JobInfo } from "./types";

type Props = {
  jobs: JobInfo[];
};

const { jobs } = Astro.props;
---

<section>
  <div class="content wrapper">
    <div class="title">
      <h2><span class="gradient">My Experience</span></h2>
      <p>Where I have Been Employed</p>
    </div>

    <div class="list">
      {
        jobs.map((job, index) => (
          <>
            <div class="job">
              <div>
                <div class="job-title">
                  <Briefcase />
                  <h3>
                    Software Developer, <span class="gradient">{job.company}</span>
                  </h3>
                </div>
                <p class="job-start-end">
                  {job.date} / {job.location}
                </p>
              </div>
              <div class="job-description">
                <p>{job.description}</p>
                {job.workTeamates && (
                  <>
                    <span class="italic">~ collaborated</span>
                    <div class="profile-photos">
                      {job.workTeamates.map((teamate) => (
                        <img src={teamate.imgURL} alt={teamate.name} />
                      ))}
                    </div>
                  </>
                )}
              </div>
            </div>
            {index !== jobs.length - 1 && <div class="line-break" />}
          </>
        ))
      }
    </div>
  </div>

  <div class="circle-gradient-left"></div>
</section>

<style>
  section {
    padding: 4rem 0;
    position: relative;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 4rem;
  }

  .title h2 {
    font-size: 1rem;
    text-transform: uppercase;
  }

  .title p {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
  }

  .job {
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding-block: 24px;
  }

  .job-title {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .job-title h3 {
    font-size: 1.25rem;
  }

  .job-start-end {
    color: var(--light-80);
    font-style: italic;
  }

  .job-description {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .job-description p {
    color: var(--light-80);
  }

  .profile-photos {
    display: flex;
    gap: 0.5rem;
  }

  .profile-photos img {
    width: 42px;
    height: 42px;
    border-radius: 50%;
  }

  .italic {
    color: var(--light-80);
    font-style: italic;
  }

  /* .job > * {
    border: 1px solid red;
  } */
</style>
