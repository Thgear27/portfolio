---
type Props = {
  title: string;
  subtitle: string;
  align?: "center" | "left" | "right";
};

const { title, subtitle, align } = Astro.props;
---

<div class="title" class:list={[{ left: align === "left", right: align === "right" }]}>
  <h2><span class="gradient">{title}</span></h2>
  <p>{subtitle}</p>
</div>

<style>
  .title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .title h2 {
    font-size: 1rem;
    text-transform: uppercase;
  }

  .title p {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    line-height: 90%;
    text-align: center;
  }

  .title.left {
    align-items: flex-start;
  }

  .title.right {
    align-items: flex-end;
  }
</style>
