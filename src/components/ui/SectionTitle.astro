---
type Props = {
  title: string;
  subtitle: string;
  align?: "center" | "left" | "right";
  mobileAlign?: "center" | "left" | "right";
};

const { title, subtitle, align, mobileAlign = "left" } = Astro.props;
---

<div
  class="title section-title"
  class:list={[
    {
      left: align === "left",
      right: align === "right",
      "m-left": mobileAlign === "left",
      "m-right": mobileAlign === "right",
      "m-center": mobileAlign === "center",
    },
  ]}
>
  <h2><span class="gradient">{title}</span></h2>
  <p>{subtitle}</p>
</div>

<style>
  .title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .title h2 {
    font-size: 1rem;
    text-transform: uppercase;
  }

  .title p {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    line-height: 90%;
    text-align: center;
  }

  .title.left {
    align-items: flex-start;
  }

  .title.right {
    align-items: flex-end;
  }

  @media (max-width: 768px) {
    .title.m-center {
      align-items: center;
    }

    .title.m-center p {
      text-align: center;
    }

    .title.m-left {
      align-items: flex-start;
    }

    .title.m-left p {
      text-align: left;
    }

    .title.m-right {
      align-items: flex-end;
    }

    .title.m-right p {
      text-align: right;
    }
  }
</style>
