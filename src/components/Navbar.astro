---
import LanguageIcon from "./svgs/LanguageIcon.astro";
import type { NavbarOption } from "./types";

type Props = {
  options: NavbarOption[];
  currentLanguage: string;
};

const { options, currentLanguage } = Astro.props;
---

<div class="nav-container wrapper">
  <div class="mobile-button">
    <input type="checkbox" id="nav-toggle" />
    <label for="nav-toggle" id="nav-toggle-button">
      <div class="humbuguer-icon">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </label>
  </div>

  <nav>
    <ul>
      {
        options.map((option) => {
          return (
            <li>
              {option.icon ? (
                <a
                  class="filled"
                  href={option.href}
                  target={option.target ? option.target : "_self"}
                  rel="noopener noreferrer"
                >
                  <span>{option.label}</span>
                  <option.icon color="var(--background-400)" />
                </a>
              ) : (
                <a class="nav-link not-filled" href={option.href} target={option.target ? option.target : "_self"}>
                  {option.label}
                </a>
              )}
            </li>
          );
        })
      }
    </ul>
  </nav>

  <div class="change-language-dropdown">
    <div class="selected-option">
      <LanguageIcon color="var(--light-80)" />
      <span>{currentLanguage}</span>
    </div>
    <div class="language-options">
      <a href="/en">EN</a>
      <a href="/es">ES</a>
    </div>
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const navToggleLabel = document.getElementById("nav-toggle-button");
    const nav = document.querySelector("nav");
    const languageDropdown = document.querySelector(".change-language-dropdown");
    const languageOptions = document.querySelector(".language-options");

    if (!navToggleLabel || !nav || !languageDropdown || !languageOptions) return;

    navToggleLabel.addEventListener("click", () => {
      nav.classList.toggle("open");
    });

    languageDropdown.addEventListener("click", () => {
      languageOptions.classList.toggle("open");
    });
  });
</script>

<style>
  .nav-container {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    gap: 1rem;
  }

  .change-language-dropdown {
    position: relative;
    box-shadow: 1px 6px 31px -3px rgba(0, 0, 0, 0.3);
    padding: 0.25rem;
    display: flex;
    gap: 8px;
    background-color: var(--background-500);
    border-radius: 100px;
    border: 1px solid var(--light-15);

    transition: transform 0.2s ease-in-out;
  }

  .selected-option {
    font-size: 0.875rem;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border-radius: 100px;
    transition: background-color 0.2s ease-in-out;
    padding: 0.25rem 0.75rem;
    user-select: none;
  }

  .selected-option:hover {
    background-color: var(--light-15);
    cursor: pointer;
  }

  .language-options {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    background-color: var(--background-500);
    border-radius: 16px;
    border: 1px solid var(--light-15);
    flex-direction: column;
    width: 100%;
    padding: 0.25rem;
  }

  .language-options.open {
    display: flex;
  }

  .language-options a {
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
  }

  .language-options a:hover {
    background-color: var(--light-15);
    cursor: pointer;
  }

  #nav-toggle {
    display: none;
  }

  .mobile-button {
    display: none;
    padding: 1rem 0;
    position: relative;
  }

  .humbuguer-icon {
    display: block;
    position: relative;
    height: 24px;
    width: 30px;
  }

  .humbuguer-icon span {
    position: absolute;
    width: 30px;
    height: 3px;
    background-color: var(--light-90);
    border-radius: 10px;
    transition:
      top 0.2s ease-in-out,
      left 0.2s ease-in-out,
      width 0.2s ease-in-out,
      transform 0.2s ease-in-out;
  }

  .humbuguer-icon span:nth-child(1) {
    left: 0;
    top: 0;
  }

  .humbuguer-icon span:nth-child(2) {
    top: 11px;
  }

  .humbuguer-icon span:nth-child(3) {
    top: 22px;
  }

  #nav-toggle:checked + label .humbuguer-icon span:nth-child(3) {
    top: 10px;
    transform: rotate(45deg);
  }

  #nav-toggle:checked + label .humbuguer-icon span:nth-child(2) {
    top: 10px;
    transform: rotate(-45deg);
  }

  #nav-toggle:checked + label .humbuguer-icon span:nth-child(1) {
    width: 0;
    top: 10px;
    left: 50%;
  }

  ul {
    box-shadow: 1px 6px 31px -3px rgba(0, 0, 0, 0.3);
    list-style: none;
    padding: 0.25rem;
    margin: 0;
    display: flex;
    gap: 1rem;
    background-color: #1e303b;
    border-radius: 100px;
    border: 1px solid var(--light-15);

    transition: transform 0.2s ease-in-out;
  }

  li {
    width: 100%;
    display: flex;
    align-items: center;
    margin: 0;
  }

  li a {
    width: 100%;
    display: flex;
    height: 100%;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    text-wrap: nowrap;
    border-radius: 100px;
    transition: background-color 0.2s ease-in-out;
  }

  .not-filled.active,
  .not-filled:hover {
    background-color: var(--light-15);
  }

  .filled {
    position: relative;
    background-color: white;
    border-radius: 100px;
    color: var(--background-400);
    overflow: hidden;
    opacity: 1;
    transition: opacity 0.2s ease-in-out;
  }

  .filled:hover {
    opacity: 0.8;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .nav-container {
      justify-content: space-between;
    }

    .mobile-button {
      display: flex;
      justify-content: flex-end;
      position: relative;
      z-index: 950;
    }

    nav {
      position: fixed;
      width: 80%;
      top: 0;
      left: 0;
      z-index: 900;
      transition: transform 0.2s ease-in-out;
      transform: translateX(-100%);
    }

    nav.open {
      transform: translateX(0);
    }

    ul {
      padding: 0;
      padding-top: 88px;
      flex-direction: column;
      align-items: start;
      width: 100%;
      height: 100vh;
      border-radius: 0;
      border: none;
      gap: 0;
    }

    li {
      width: 100%;
      border-bottom: 1px solid var(--light-15);
    }

    li a {
      padding-top: 1rem;
      padding-bottom: 1rem;
      justify-content: start;
      border-radius: 0;
    }
  }
</style>
