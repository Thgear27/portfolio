---
import EmailLogo from "./svgs/social/EmailLogo.astro";
import type { SocialLink } from "./types";

export type Props = {
  socialLinks: SocialLink[];
  email: string;
};

const { socialLinks, email } = Astro.props;
---

<section id="home">
  <div class="content wrapper">
    <div class="title">
      <h1>Hello, I'm <span class="gradient">Fernando</span></h1>
      <p class="subtitle">Web Developer - Problem Solver</p>
    </div>
    <p class="text">
      I build
      <span class="highlight">fast</span>,
      <span class="highlight">modern</span>, and
      <span class="highlight">user-friendly</span> web experiences. Passionate about clean code, performance, and crafting
      digital solutions that make an impact.
    </p>
    <div class="social-links">
      {
        socialLinks.map((link) => {
          return (
            <a href={link.href} target={link.target ? link.target : "_blank"} rel="noopener noreferrer">
              <link.icon color="var(--light-90)" />
              <span>{link.label}</span>
            </a>
          );
        })
      }

      <a href={`mailto:${email}?subject=Hello Fernando!, I would like to work with you`}>
        <EmailLogo />
        <span>Email me</span>
      </a>
    </div>
  </div>

  <div class="circle-gradient-right"></div>
</section>

<style>
  .content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  section {
    padding: 9rem 0;
    position: relative;
  }

  .subtitle {
    color: var(--light-80);
  }

  .text {
    font-size: 1.25rem;
    color: var(--light-90);
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    row-gap: 0.5rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 4px 16px;
    border: 1px solid var(--light-30);
    border-radius: 100px;
    color: var(--light-90);
    background-color: #00000000;
    transition: background-color 0.2s ease
  }

  .social-links a:hover {
    background-color: var(--light-10);
  }

  .social-links a :global(svg) {
    height: 15px;
    width: 15px;
  }

  .social-links span {
    font-size: 1rem;
    font-weight: 400;
  }

  @media (max-width: 768px) {
    section {
      padding: 3rem 0;
    }
  }
</style>
